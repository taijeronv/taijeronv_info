---
import { skills } from '../data/skills';
---
<section id="skills" class="py-24 px-6 bg-gray-950 text-white">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl font-bold mb-12">AI Skills</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {skills.map((skill) => (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-blue-400 mb-4">{skill.name}</h3>
          <ul class="space-y-2">
            {skill.uses.map((use) => (
              <li class="text-gray-400 text-sm flex items-start gap-2">
                <span class="text-blue-600 mt-0.5 shrink-0">▸</span>
                <span>{use}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
