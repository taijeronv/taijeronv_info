---
import { getCollection } from 'astro:content';
const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);
---
<section id="projects" class="py-24 px-6 bg-gray-900 text-white">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl font-bold mb-12">Projects</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {projects.map((project) => (
        <div class="bg-gray-800 border border-gray-700 rounded-xl p-6 flex flex-col">
          <h3 class="text-lg font-semibold text-white mb-2">{project.data.title}</h3>
          <p class="text-gray-400 text-sm mb-4">{project.data.description}</p>
          <ul class="space-y-3">
            {project.data.bullets.map((bullet) => (
              <li class="text-gray-300 text-sm flex items-start gap-2">
                <span class="text-blue-400 mt-0.5 shrink-0">▸</span>
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
